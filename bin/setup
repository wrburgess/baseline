#!/usr/bin/env ruby
require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)

def system!(*args)
  system(*args, exception: true)
end

def step(name)
  puts "\n== #{name} =="
end

def check_command(name, install_hint)
  unless system("command -v #{name} > /dev/null 2>&1")
    warn "  Warning: #{name} not found. #{install_hint}"
    return false
  end
  true
end

FileUtils.chdir APP_ROOT do
  # This script is a way to set up or update your development environment automatically.
  # This script is idempotent, so that you can run it at any time and get an expectable outcome.

  step "Checking prerequisites"
  has_mise = check_command("mise", "Run: brew install mise")
  has_op = check_command("op", "Run: brew install --cask 1password-cli")

  if has_mise
    step "Installing runtimes (mise install)"
    system! "mise install"
  end

  if has_op
    step "Fetching credentials from 1Password"
    system! "bin/setup-credentials"
  elsif !File.exist?("config/credentials/development.key")
    warn "  Warning: config/credentials/development.key is missing and 1Password CLI is not available."
    warn "  Get the key from a team member or install the 1Password CLI and run: bin/setup-credentials"
  else
    puts "  Skipping (development.key already exists)"
  end

  step "Installing gem dependencies"
  system("bundle check") || system!("bundle install")

  step "Preparing database"
  system! "bin/rails db:prepare"
  system! "bin/rails db:reset" if ARGV.include?("--reset")

  step "Installing git hooks"
  system! "bin/install-git-hooks"

  step "Removing old logs and tempfiles"
  system! "bin/rails log:clear tmp:clear"

  unless ARGV.include?("--skip-server")
    step "Starting development server"
    STDOUT.flush # flush the output before exec(2) so that it displays
    exec "bin/dev"
  end
end
