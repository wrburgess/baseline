#!/usr/bin/env bash
#
# Fetches Rails credentials keys from 1Password and writes them to config/credentials/.
#
# Usage: bin/setup-credentials [--all]
#
#   By default, only fetches the development key.
#   Use --all to fetch development, staging, and production keys.
#
# Requires:
#   - 1Password CLI (`brew install --cask 1password-cli`)
#   - CLI integration enabled in 1Password app (Settings > Developer > Integrate with 1Password CLI)
#   - Access to the "Application Development" vault on mpimediagroup.1password.com

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
CREDENTIALS_DIR="$PROJECT_DIR/config/credentials"
OP_ACCOUNT="mpimediagroup.1password.com"
OP_VAULT="Application Development"

if ! command -v op &>/dev/null; then
  echo "Error: 1Password CLI not installed. Run: brew install --cask 1password-cli" >&2
  exit 1
fi

mkdir -p "$CREDENTIALS_DIR"

capitalize() {
  local first="${1:0:1}"
  local rest="${1:1}"
  printf '%s%s' "$(echo "$first" | tr '[:lower:]' '[:upper:]')" "$rest"
}

fetch_key() {
  local env="$1"
  local item_name="Optimus $(capitalize "$env") Key"
  local key_file="$CREDENTIALS_DIR/${env}.key"

  if [[ -f "$key_file" ]]; then
    echo "  Skipping $env (${key_file##*/} already exists)"
    return 0
  fi

  local key
  key=$(op read "op://$OP_VAULT/$item_name/credential" --account="$OP_ACCOUNT") || {
    echo "  Failed to read $item_name from 1Password" >&2
    return 1
  }

  printf '%s' "$key" > "$key_file"
  chmod 600 "$key_file"
  echo "  Written: ${key_file##*/} (chmod 600)"
}

echo "Fetching Rails credentials keys from 1Password..."
echo "(You may be prompted by 1Password verification once)"
echo ""

ENVIRONMENTS=("development")
if [[ "${1:-}" == "--all" ]]; then
  ENVIRONMENTS=("development" "staging" "production")
fi

FAILED=0
for env in "${ENVIRONMENTS[@]}"; do
  fetch_key "$env" || FAILED=1
done

echo ""
if [[ $FAILED -eq 0 ]]; then
  echo "Done. Verify with: bin/rails credentials:show --environment development"
else
  echo "Some keys failed to fetch. Check the errors above." >&2
  exit 1
fi

# ---------------------------------------------------------------------------
# Honeybadger CLI configuration
# ---------------------------------------------------------------------------
# Customize this variable for each project. The item name must match the
# 1Password entry in the "Application Development" vault:
#   "{AppName} Production Honeybadger" with fields: api_key, project_id
# ---------------------------------------------------------------------------
HB_PRODUCTION_ITEM="Optimus Production Honeybadger"
HB_GLOBAL_CONFIG="$HOME/.honeybadger-cli.yaml"
HB_PROJECT_CONFIG="$PROJECT_DIR/.honeybadger-cli.yaml"

echo "Configuring Honeybadger CLI..."
echo ""

if ! command -v hb &>/dev/null; then
  echo "  Warning: Honeybadger CLI not installed. Run: brew install honeybadger-io/tap/honeybadger" >&2
  echo "  Skipping Honeybadger CLI configuration."
else
  # Write the global auth token config (shared across all MPI projects) — skip if exists
  if [[ -f "$HB_GLOBAL_CONFIG" ]]; then
    echo "  Skipping ~/.honeybadger-cli.yaml (already exists)"
    HB_AUTH_TOKEN=$(grep 'auth_token:' "$HB_GLOBAL_CONFIG" | awk '{print $2}')
  else
    HB_AUTH_TOKEN=$(op read "op://$OP_VAULT/Honeybadger Auth Token/credential" --account="$OP_ACCOUNT") || {
      echo "  Failed to read Honeybadger Auth Token from 1Password" >&2
      exit 1
    }
    cat > "$HB_GLOBAL_CONFIG" <<YAML
auth_token: $HB_AUTH_TOKEN
YAML
    chmod 600 "$HB_GLOBAL_CONFIG"
    echo "  Written: ~/.honeybadger-cli.yaml (chmod 600)"
  fi

  # Write the project-level config (always overwritten so it stays up to date)
  HB_API_KEY=$(op read "op://$OP_VAULT/$HB_PRODUCTION_ITEM/api_key" --account="$OP_ACCOUNT") || {
    echo "  Failed to read $HB_PRODUCTION_ITEM api_key from 1Password" >&2
    exit 1
  }
  HB_PROJECT_ID=$(op read "op://$OP_VAULT/$HB_PRODUCTION_ITEM/project_id" --account="$OP_ACCOUNT") || {
    echo "  Failed to read $HB_PRODUCTION_ITEM project_id from 1Password" >&2
    exit 1
  }

  cat > "$HB_PROJECT_CONFIG" <<YAML
auth_token: $HB_AUTH_TOKEN
api_key: $HB_API_KEY
project_id: $HB_PROJECT_ID
YAML
  chmod 600 "$HB_PROJECT_CONFIG"
  echo "  Written: .honeybadger-cli.yaml (chmod 600)"

  echo ""
  echo "Honeybadger CLI configured. Use bin/hb to interact with the project."
fi
