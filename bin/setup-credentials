#!/usr/bin/env bash
#
# Fetches Rails credentials keys from 1Password and writes them to config/credentials/.
#
# Usage: bin/setup-credentials [--all]
#
#   By default, only fetches the development key.
#   Use --all to fetch development, staging, and production keys.
#
# Requires:
#   - 1Password CLI (`brew install --cask 1password-cli`)
#   - CLI integration enabled in 1Password app (Settings > Developer > Integrate with 1Password CLI)
#   - BASELINE_OP_ACCOUNT env var set to your 1Password account (e.g. my.1password.com)
#   - Access to the vault specified by BASELINE_OP_VAULT (default: "Application Development")

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
CREDENTIALS_DIR="$PROJECT_DIR/config/credentials"
OP_ACCOUNT="${BASELINE_OP_ACCOUNT:?Set BASELINE_OP_ACCOUNT env var (e.g. my.1password.com)}"
OP_VAULT="${BASELINE_OP_VAULT:-Application Development}"

if ! command -v op &>/dev/null; then
  echo "Error: 1Password CLI not installed. Run: brew install --cask 1password-cli" >&2
  exit 1
fi

mkdir -p "$CREDENTIALS_DIR"

capitalize() {
  local first="${1:0:1}"
  local rest="${1:1}"
  printf '%s%s' "$(echo "$first" | tr '[:lower:]' '[:upper:]')" "$rest"
}

fetch_key() {
  local env="$1"
  local item_name="Baseline $(capitalize "$env") Key"
  local key_file="$CREDENTIALS_DIR/${env}.key"

  if [[ -f "$key_file" ]]; then
    echo "  Skipping $env (${key_file##*/} already exists)"
    return 0
  fi

  local key
  key=$(op read "op://$OP_VAULT/$item_name/credential" --account="$OP_ACCOUNT") || {
    echo "  Failed to read $item_name from 1Password" >&2
    return 1
  }

  printf '%s' "$key" > "$key_file"
  chmod 600 "$key_file"
  echo "  Written: ${key_file##*/} (chmod 600)"
}

echo "Fetching Rails credentials keys from 1Password..."
echo "(You may be prompted by 1Password verification once)"
echo ""

ENVIRONMENTS=("development")
if [[ "${1:-}" == "--all" ]]; then
  ENVIRONMENTS=("development" "staging" "production")
fi

FAILED=0
for env in "${ENVIRONMENTS[@]}"; do
  fetch_key "$env" || FAILED=1
done

echo ""
if [[ $FAILED -eq 0 ]]; then
  echo "Done. Verify with: bin/rails credentials:show --environment development"
else
  echo "Some keys failed to fetch. Check the errors above." >&2
  exit 1
fi
