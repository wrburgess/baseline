#!/usr/bin/env bash
#
# Generates .mcp.json from .mcp.json.example by fetching credentials from 1Password.
#
# Usage:
#   bin/setup-mcp            # Fetch credentials and write .mcp.json
#   bin/setup-mcp --dry-run  # Show which credentials would be fetched without writing
#
# Requires:
#   - 1Password CLI (`brew install --cask 1password-cli`)
#   - CLI integration enabled in 1Password app (Settings > Developer > Integrate with 1Password CLI)
#   - Access to the "Application Development" vault on mpimediagroup.1password.com
#
# MCP Server Profile (Optimized — see docs/architecture/mcp-integration-audit.md):
#   - Cloudflare (Code Mode) — full API access via 2 tools
#   - Honeybadger — error tracking across MPI projects
#
# Removed servers (use CLI tools instead):
#   - GitHub → use `gh` CLI (`gh auth login`)
#   - Heroku → use `heroku` CLI (`heroku login`)
#   - AWS → use `aws` CLI (`aws configure`)
#   - DigitalOcean → use `doctl` CLI (`doctl auth init`)
#   - Context7 → use Context7 plugin (enabled in ~/.claude/settings.json)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
EXAMPLE_FILE="$PROJECT_DIR/.mcp.json.example"
OUTPUT_FILE="$PROJECT_DIR/.mcp.json"
OP_ACCOUNT="mpimediagroup.1password.com"
OP_VAULT="Application Development"
DRY_RUN=false

if [[ "${1:-}" == "--dry-run" ]]; then
  DRY_RUN=true
fi

if [[ ! -f "$EXAMPLE_FILE" ]]; then
  echo "Error: $EXAMPLE_FILE not found" >&2
  exit 1
fi

if ! command -v op &>/dev/null; then
  echo "Error: 1Password CLI not installed. Run: brew install --cask 1password-cli" >&2
  exit 1
fi

if ! command -v npx &>/dev/null; then
  echo "Error: npx not found. Install Node.js first." >&2
  exit 1
fi

echo "MCP Server Profile: Cloudflare (Code Mode), Honeybadger"
echo "See docs/architecture/mcp-integration-audit.md for rationale"
echo ""

if [[ "$DRY_RUN" == true ]]; then
  echo "[DRY RUN] Would fetch the following credentials from 1Password:"
  echo "  - Cloudflare API Key  (op://$OP_VAULT/Cloudflare API Key/credential)"
  echo "  - Honeybadger API Key (op://$OP_VAULT/Honeybadger API Key/credential)"
  echo ""
  echo "[DRY RUN] Would write: $OUTPUT_FILE"
  echo "[DRY RUN] Template: $EXAMPLE_FILE"
  echo ""
  echo "Servers NOT included (use CLI tools instead):"
  echo "  - GitHub       → gh auth login"
  echo "  - Heroku       → heroku login"
  echo "  - AWS          → aws configure"
  echo "  - DigitalOcean → doctl auth init"
  echo "  - Context7     → Context7 plugin (auto-enabled)"
  exit 0
fi

echo "Fetching credentials from 1Password..."
echo "(You may be prompted by 1Password verification once)"
echo ""

# Fetch all credentials in one burst so 1Password keeps the session active
CLOUDFLARE_API_TOKEN=$(op read "op://$OP_VAULT/Cloudflare API Key/credential" --account="$OP_ACCOUNT") || { echo "Failed to read Cloudflare API Key" >&2; exit 1; }
HONEYBADGER_API_KEY=$(op read "op://$OP_VAULT/Honeybadger API Key/credential" --account="$OP_ACCOUNT") || { echo "Failed to read Honeybadger API Key" >&2; exit 1; }

echo "All credentials fetched successfully."

# Read the example file and substitute placeholders with real values
content=$(<"$EXAMPLE_FILE")
content="${content//\$\{CLOUDFLARE_API_TOKEN\}/$CLOUDFLARE_API_TOKEN}"
content="${content//\$\{HONEYBADGER_API_KEY\}/$HONEYBADGER_API_KEY}"

printf '%s\n' "$content" > "$OUTPUT_FILE"
chmod 600 "$OUTPUT_FILE"

echo ""
echo "Written: $OUTPUT_FILE (chmod 600)"
echo ""
echo "Reminder: Ensure CLI tools are authenticated:"
echo "  gh auth login          # GitHub"
echo "  heroku login           # Heroku (if needed)"
echo "  doctl auth init        # DigitalOcean (if needed)"
echo "  aws configure          # AWS (if needed)"
echo ""
echo "Done. You can now start Claude Code in this project."
